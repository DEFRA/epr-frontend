{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "report-section/macro.njk" import reportSection %}

{#
  The read-only PRN/PERN summary shared by the submit and view pages: the issued
  tonnage as a section headline, then a revenue / free / average-price list. The
  editable check page differs (issued in the list, Change links) so keeps its own.
#}
{% macro readOnlyPrnSummary(prn, labels) %}
  {{ reportSection(labels.section, labels.issued, prn.issuedTonnage | formatWholeNumberTonnage) }}

  {% set freeKeyHtml %}
    {{ labels.free }}
    <span class="govuk-body-s govuk-!-font-weight-regular govuk-!-display-block govuk-!-margin-top-1">{{ labels.freeNote }}</span>
  {% endset %}

  {{ govukSummaryList({
    classes: "epr-summary-list--wide-key",
    rows: [
      {
        key: { text: labels.revenue },
        value: { text: prn.totalRevenue | formatCurrency }
      },
      {
        key: { html: freeKeyHtml },
        value: { text: prn.freeTonnage | formatWholeNumberTonnage }
      },
      {
        key: { text: labels.avg },
        value: { text: prn.averagePricePerTonne | formatCurrency }
      }
    ]
  }) }}
{% endmacro %}
