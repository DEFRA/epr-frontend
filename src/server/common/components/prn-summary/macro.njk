{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "report-section/macro.njk" import reportSection %}

{#
  The PRN/PERN summary shared by all three report pages.

  - editable (check-your-answers): issued tonnage is a row, revenue and free
    carry Change links (pass revenueChangeUrl / freeChangeUrl / changeText).
  - read-only (submit, view): issued tonnage is a section headline, no Change.

  On the editable page a report can still be incomplete, so any value may be
  null and renders as a dash. On the read-only pages every value has already
  been captured on its own mandatory step, so they are always shown.
#}
{% macro prnSummary(prn, labels, options) %}
  {% set editable = options.editable %}

  {% set issuedValue = (prn.issuedTonnage | formatWholeNumberTonnage) if prn.issuedTonnage is defined and prn.issuedTonnage !== null else "—" %}
  {% set revenueValue = (prn.totalRevenue | formatCurrency) if prn.totalRevenue is defined and prn.totalRevenue !== null else "—" %}
  {% set freeValue = (prn.freeTonnage | formatWholeNumberTonnage) if prn.freeTonnage is defined and prn.freeTonnage !== null else "—" %}
  {% set avgValue = (prn.averagePricePerTonne | formatCurrency) if prn.averagePricePerTonne is defined and prn.averagePricePerTonne !== null else "—" %}

  {% if editable %}
    <h2 class="govuk-heading-l">{{ labels.section }}</h2>
  {% else %}
    {{ reportSection(labels.section, labels.issued, issuedValue) }}
  {% endif %}

  {% set freeKeyHtml %}
    {{ labels.free }}
    <span class="govuk-body-s govuk-!-font-weight-regular govuk-!-display-block govuk-!-margin-top-1">{{ labels.freeNote }}</span>
  {% endset %}

  {% set rows = [] %}

  {% if editable %}
    {% set rows = rows.concat([{
      key: { text: labels.issued },
      value: { text: issuedValue }
    }]) %}
  {% endif %}

  {% set rows = rows.concat([
    {
      key: { text: labels.revenue },
      value: { text: revenueValue },
      actions: { items: [{ href: options.revenueChangeUrl, text: options.changeText, visuallyHiddenText: labels.revenue }] } if editable else none
    },
    {
      key: { html: freeKeyHtml },
      value: { text: freeValue },
      actions: { items: [{ href: options.freeChangeUrl, text: options.changeText, visuallyHiddenText: labels.free }] } if editable else none
    },
    {
      key: { text: labels.avg },
      value: { text: avgValue }
    }
  ]) %}

  {{ govukSummaryList({ classes: "epr-summary-list--wide-key", rows: rows }) }}
{% endmacro %}
