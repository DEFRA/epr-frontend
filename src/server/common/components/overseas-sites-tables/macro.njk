{% from "govuk/components/table/macro.njk" import govukTable %}

{% macro overseasSitesTables(params) %}
  {% if params.approvedRows | length > 0 %}
    <h3 class="govuk-heading-m">{{ params.approvedHeading }}</h3>
    {{ govukTable({
      head: params.approvedHead,
      rows: params.approvedRows
    }) }}
  {% endif %}

  {% if params.unapprovedRows | length > 0 %}
    <h3 class="govuk-heading-m">{{ params.unapprovedHeading }}</h3>
    <div class="govuk-inset-text">{{ params.unapprovedIntro }}</div>
    {{ govukTable({
      head: params.unapprovedHead,
      rows: params.unapprovedRows
    }) }}
  {% endif %}
{% endmacro %}
