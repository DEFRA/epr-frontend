{% extends 'layouts/page.njk' %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block content %}
  {{ govukBackLink({ text: "Back", href: backUrl }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if errorSummary %}
        {{ govukErrorSummary(errorSummary) }}
      {% endif %}

      <h1 class="govuk-heading-l">{{ heading }}</h1>
      <p class="govuk-body">These details are optional. Leave blank any you do not have.</p>

      <form method="post" action="{{ formAction }}" novalidate>
        <input type="hidden" name="crumb" value="{{ crumb }}">

        {{ govukInput({
          id: "carrierName",
          name: "carrierName",
          label: { text: "Carrier name", classes: "govuk-label--m" },
          value: values.carrierName,
          errorMessage: errors.carrierName
        }) }}

        {{ govukInput({
          id: "cbdRegNumber",
          name: "cbdRegNumber",
          label: { text: "CBD registration number", classes: "govuk-label--m" },
          classes: "govuk-input--width-20",
          value: values.cbdRegNumber,
          errorMessage: errors.cbdRegNumber
        }) }}

        {{ govukInput({
          id: "vehicleRegistration",
          name: "vehicleRegistration",
          label: { text: "Vehicle registration number", classes: "govuk-label--m" },
          classes: "govuk-input--width-10",
          value: values.vehicleRegistration,
          errorMessage: errors.vehicleRegistration
        }) }}

        {{ govukInput({
          id: "weighbridgeTicket",
          name: "weighbridgeTicket",
          label: { text: "Weighbridge ticket number", classes: "govuk-label--m" },
          classes: "govuk-input--width-20",
          value: values.weighbridgeTicket,
          errorMessage: errors.weighbridgeTicket
        }) }}

        {{ govukInput({
          id: "yourReference",
          name: "yourReference",
          label: { text: "Your reference", classes: "govuk-label--m" },
          value: values.yourReference,
          errorMessage: errors.yourReference
        }) }}

        {{ govukButton({ text: "Continue" }) }}
      </form>
    </div>
  </div>
{% endblock %}
