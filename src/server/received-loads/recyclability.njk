{% extends 'layouts/page.njk' %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block content %}
  {{ govukBackLink({ text: "Back", href: backUrl }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if errorSummary %}
        {{ govukErrorSummary(errorSummary) }}
      {% endif %}

      <h1 class="govuk-heading-l">{{ heading }}</h1>
      <p class="govuk-body">The tonnage received for recycling is worked out from these answers and the net weight.</p>

      <form method="post" action="{{ formAction }}" novalidate>
        <input type="hidden" name="crumb" value="{{ crumb }}">

        {{ govukRadios({
          name: "bailingWireProtocol",
          fieldset: {
            legend: { text: "Was the bailing wire protocol applied?", classes: "govuk-fieldset__legend--m" }
          },
          hint: { text: "If yes, a 0.15% deduction is applied to the weight" },
          items: bailingItems,
          errorMessage: errors.bailingWireProtocol
        }) }}

        {{ govukSelect({
          id: "calculationMethod",
          name: "calculationMethod",
          label: { text: "How did you calculate the recyclable proportion?", classes: "govuk-label--m" },
          items: methodItems,
          errorMessage: errors.calculationMethod
        }) }}

        {{ govukInput({
          id: "nonTargetWeight",
          name: "nonTargetWeight",
          label: { text: "Weight of non-target materials", classes: "govuk-label--m" },
          classes: "govuk-input--width-10",
          spellcheck: false,
          inputmode: "decimal",
          suffix: { text: "tonnes" },
          value: values.nonTargetWeight,
          errorMessage: errors.nonTargetWeight
        }) }}

        {{ govukInput({
          id: "recyclablePercentage",
          name: "recyclablePercentage",
          label: { text: "Recyclable proportion", classes: "govuk-label--m" },
          classes: "govuk-input--width-5",
          spellcheck: false,
          inputmode: "decimal",
          suffix: { text: "%" },
          value: values.recyclablePercentage,
          errorMessage: errors.recyclablePercentage
        }) }}

        {{ govukButton({ text: "Continue" }) }}
      </form>
    </div>
  </div>
{% endblock %}
