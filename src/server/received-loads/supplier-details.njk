{% extends 'layouts/page.njk' %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block content %}
  {{ govukBackLink({ text: "Back", href: backUrl }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if errorSummary %}
        {{ govukErrorSummary(errorSummary) }}
      {% endif %}

      <h1 class="govuk-heading-l">{{ heading }}</h1>
      <p class="govuk-body">These details are optional. Leave blank any you do not have.</p>

      <form method="post" action="{{ formAction }}" novalidate>
        <input type="hidden" name="crumb" value="{{ crumb }}">

        {{ govukInput({
          id: "supplierName",
          name: "supplierName",
          label: { text: "Supplier name", classes: "govuk-label--m" },
          value: values.supplierName,
          errorMessage: errors.supplierName
        }) }}

        {{ govukTextarea({
          id: "supplierAddress",
          name: "supplierAddress",
          label: { text: "Supplier address", classes: "govuk-label--m" },
          rows: 3,
          value: values.supplierAddress,
          errorMessage: errors.supplierAddress
        }) }}

        {{ govukInput({
          id: "supplierPostcode",
          name: "supplierPostcode",
          label: { text: "Supplier postcode", classes: "govuk-label--m" },
          classes: "govuk-input--width-10",
          value: values.supplierPostcode,
          errorMessage: errors.supplierPostcode
        }) }}

        {{ govukInput({
          id: "supplierEmail",
          name: "supplierEmail",
          label: { text: "Supplier email address", classes: "govuk-label--m" },
          value: values.supplierEmail,
          errorMessage: errors.supplierEmail
        }) }}

        {{ govukInput({
          id: "supplierPhone",
          name: "supplierPhone",
          label: { text: "Supplier phone number", classes: "govuk-label--m" },
          classes: "govuk-input--width-20",
          value: values.supplierPhone,
          errorMessage: errors.supplierPhone
        }) }}

        {{ govukTextarea({
          id: "activitiesCarriedOut",
          name: "activitiesCarriedOut",
          label: { text: "Activities carried out by the supplier", classes: "govuk-label--m" },
          rows: 3,
          value: values.activitiesCarriedOut,
          errorMessage: errors.activitiesCarriedOut
        }) }}

        {{ govukButton({ text: "Continue" }) }}
      </form>
    </div>
  </div>
{% endblock %}
