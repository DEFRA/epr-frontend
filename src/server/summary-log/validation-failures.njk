{% extends 'layouts/page.njk' %}
{% from "summary-log-upload/macro.njk" import summaryLogUpload %}

{% block beforeContent %}
  {{ govukBackLink({
    text: localise("common:back"),
    href: cancelUrl
  }) }}
{% endblock %}

{% block content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <div class="govuk-body" data-testid="app-page-body">
      <h1 class="govuk-heading-xl">{{ heading }}</h1>
      <p>{{ description1 }}</p>
      <p>{{ description2 }}</p>

      {% for group in errorGroups %}
        <h2 class="govuk-heading-m">{{ group.worksheetLabel }}</h2>
        <h3 class="govuk-heading-s">{{ group.sectionLabel }}</h3>
        <table class="govuk-table">
          <caption class="govuk-table__caption govuk-visually-hidden">{{ group.sectionLabel }}</caption>
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">{{ localise("summary-log:cellTable.rowIdHeading") }}</th>
              <th scope="col" class="govuk-table__header">{{ localise("summary-log:cellTable.columnHeading") }}</th>
              <th scope="col" class="govuk-table__header">{{ localise("summary-log:cellTable.valueHeading") }}</th>
              <th scope="col" class="govuk-table__header">{{ localise("summary-log:cellTable.problemHeading") }}</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for row in group.rows %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">{{ row.rowId }}</td>
                <td class="govuk-table__cell">{{ row.columnLabel }}</td>
                <td class="govuk-table__cell">{{ row.value }}</td>
                <td class="govuk-table__cell">{{ row.problem }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% endfor %}

      {% for issue in issues %}
        <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">
        {% if issue.type == 'sequentialRowRemoved' %}
          <p class="govuk-body govuk-!-font-weight-bold">{{ issue.preamble }}</p>
          <ul class="govuk-list govuk-list--bullet govuk-!-font-weight-bold">
            {% for sheet in issue.sheets %}
              <li>{{ sheet }}</li>
            {% endfor %}
          </ul>
          <p class="govuk-body govuk-!-font-weight-bold">{{ issue.closing }}</p>
        {% else %}
          <p class="govuk-body govuk-!-font-weight-bold">{{ issue }}</p>
        {% endif %}
      {% endfor %}

      <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

      {{ summaryLogUpload({
        uploadUrl: uploadUrl,
        fileUploadLabel: fileUploadLabel,
        buttonText: buttonText,
        cancelUrl: cancelUrl,
        cancelButtonText: cancelButtonText
      }) }}
    </div>
  </div>
</div>
{% endblock %}
