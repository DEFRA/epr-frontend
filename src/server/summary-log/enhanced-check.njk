{% extends 'layouts/page.njk' %}

{# Section banding follows the design: the heading plus any inset and tonnage
   caption form an un-ruled intro, then a rule precedes every content block and a
   trailing rule closes the section. No rule sits above the first heading. #}
{% macro sectionRule() %}
  <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible">
{% endmacro %}

{# Bullet list of loads: the operator's worksheet (tab) name, Row ID, and any
   exclusion reason. The reason is omitted where the row carries none. #}
{% macro loadRows(rows) %}
  <ul class="govuk-list govuk-list--bullet">
    {% for row in rows %}
    <li>
      {% if row.reasonText %}
      {{ localise('summary-log:enhanced.loadRowWithReason', { worksheetName: row.worksheetName, rowId: row.rowId, reason: row.reasonText }) }}
      {% else %}
      {{ localise('summary-log:enhanced.loadRow', { worksheetName: row.worksheetName, rowId: row.rowId }) }}
      {% endif %}
    </li>
    {% endfor %}
  </ul>
{% endmacro %}

{# "Show [x] load[s]" disclosure wrapping the bullet list of rows. Over the cap
   (more than 99 loads) the list is suppressed for the too-many message, matching
   the row-id-list convention. #}
{% macro loadsAccordion(count, rows, tooManyMessage) %}
  {% if count > 99 %}
  <p class="govuk-body">{{ tooManyMessage }}</p>
  {% else %}
  <details class="govuk-details">
    <summary class="govuk-details__summary">
      <span class="govuk-details__summary-text">{{ localise('summary-log:showLoads', { count: count }) }}</span>
    </summary>
    <div class="govuk-details__text">
      {{ loadRows(rows) }}
    </div>
  </details>
  {% endif %}
{% endmacro %}

{# Adjusted balance-affecting disclosure: one "Show [x] load[s]" toggle holding
   the with-data sub-group (its heading reflects the group's direction) and the
   missing-data sub-group (which always reduces the balance). #}
{% macro adjustedBalanceAccordion(balanceAffecting, tooManyMessage) %}
  {% if balanceAffecting.count > 99 %}
  <p class="govuk-body">{{ tooManyMessage }}</p>
  {% else %}
  <details class="govuk-details">
    <summary class="govuk-details__summary">
      <span class="govuk-details__summary-text">{{ localise('summary-log:showLoads', { count: balanceAffecting.count }) }}</span>
    </summary>
    <div class="govuk-details__text">
      {% if balanceAffecting.withData.rows.length > 0 %}
        {% if balanceAffecting.withData.addsToBalance %}
        <p class="govuk-body govuk-!-font-weight-bold">{{ localise('summary-log:enhanced.adjustedWithDataAdded', { count: balanceAffecting.withData.rows.length }) }}</p>
        {% else %}
        <p class="govuk-body govuk-!-font-weight-bold">{{ localise('summary-log:enhanced.adjustedWithDataReduced', { count: balanceAffecting.withData.rows.length }) }}</p>
        {% endif %}
        {{ loadRows(balanceAffecting.withData.rows) }}
      {% endif %}
      {% if balanceAffecting.withoutData.rows.length > 0 %}
      <p class="govuk-body govuk-!-font-weight-bold">{{ localise('summary-log:enhanced.adjustedWithoutData', { count: balanceAffecting.withoutData.rows.length }) }}</p>
      {{ loadRows(balanceAffecting.withoutData.rows) }}
      {% endif %}
    </div>
  </details>
  {% endif %}
{% endmacro %}

{% macro newLoadsSection(change, headingKey, isAccredited) %}
<section class="govuk-!-margin-top-6">
  <h2 class="govuk-heading-l">{{ localise('summary-log:enhanced.' + headingKey) }}</h2>
  {% if isAccredited %}
    {% if change.hasTonnageDelta %}
    <p class="govuk-body">{{ localise('summary-log:enhanced.newLoadsCaption', { tonnage: change.absoluteTonnage }) }}</p>
    {% endif %}
    {% if change.balanceAffecting.count > 0 %}
    {{ sectionRule() }}
    <h3 class="govuk-heading-m">{{ localise('summary-log:enhanced.newLoadsAddedHeading', { count: change.balanceAffecting.count }) }}</h3>
    <p class="govuk-body">{{ localise('summary-log:enhanced.loadsIncludeData') }}</p>
    {% endif %}
    {% if change.nonBalanceAffecting.count > 0 %}
    {{ sectionRule() }}
    <h3 class="govuk-heading-m">{{ localise('summary-log:enhanced.newLoadsNotAddedHeading', { count: change.nonBalanceAffecting.count }) }}</h3>
    <p class="govuk-body">{{ localise('summary-log:enhanced.newLoadsNotAddedBody') }}</p>
    {{ loadsAccordion(change.nonBalanceAffecting.count, change.nonBalanceAffecting.rows, localise('summary-log:enhanced.tooManyLoads')) }}
    {% endif %}
  {% else %}
    {{ sectionRule() }}
    <h3 class="govuk-heading-m">{{ localise('summary-log:enhanced.regOnlyNewLoadsHeading', { count: change.count }) }}</h3>
    <p class="govuk-body">{{ localise('summary-log:enhanced.regOnlyLoadsBody') }}</p>
    {{ loadsAccordion(change.nonBalanceAffecting.count, change.nonBalanceAffecting.rows, localise('summary-log:enhanced.tooManyLoads')) }}
  {% endif %}
  {{ sectionRule() }}
</section>
{% endmacro %}

{% macro adjustedLoadsSection(change, headingKey, isAccredited, showInset) %}
<section class="govuk-!-margin-top-6">
  <h2 class="govuk-heading-l">{{ localise('summary-log:enhanced.' + headingKey) }}</h2>
  {% if showInset %}
  <div class="govuk-inset-text">{{ localise('summary-log:enhanced.adjustedDataChangedInset') }}</div>
  {% endif %}
  {% if isAccredited %}
    {% if change.hasTonnageDelta %}
      {% if change.addsToBalance %}
      <p class="govuk-body">{{ localise('summary-log:enhanced.adjustedLoadsCaptionAdd', { tonnage: change.absoluteTonnage }) }}</p>
      {% else %}
      <p class="govuk-body">{{ localise('summary-log:enhanced.adjustedLoadsCaptionRemove', { tonnage: change.absoluteTonnage }) }}</p>
      {% endif %}
    {% endif %}
    {% if change.balanceAffecting.count > 0 %}
    {{ sectionRule() }}
    <h3 class="govuk-heading-m">{{ localise('summary-log:enhanced.adjustedLoadsReflectedHeading', { count: change.balanceAffecting.count }) }}</h3>
    <p class="govuk-body">{{ localise('summary-log:enhanced.adjustedLoadsReflectedBody') }}</p>
    {{ adjustedBalanceAccordion(change.balanceAffecting, localise('summary-log:tooManyAdjustedLoadsToList')) }}
    {% endif %}
    {% if change.nonBalanceAffecting.count > 0 %}
    {{ sectionRule() }}
    <h3 class="govuk-heading-m">{{ localise('summary-log:enhanced.adjustmentsNotRelevantHeading', { count: change.nonBalanceAffecting.count }) }}</h3>
    {{ loadsAccordion(change.nonBalanceAffecting.count, change.nonBalanceAffecting.rows, localise('summary-log:tooManyAdjustedLoadsToList')) }}
    {% endif %}
  {% else %}
    {{ sectionRule() }}
    <h3 class="govuk-heading-m">{{ localise('summary-log:enhanced.regOnlyAdjustedLoadsHeading', { count: change.count }) }}</h3>
    <p class="govuk-body">{{ localise('summary-log:enhanced.regOnlyLoadsBody') }}</p>
    {{ loadsAccordion(change.nonBalanceAffecting.count, change.nonBalanceAffecting.rows, localise('summary-log:tooManyAdjustedLoadsToList')) }}
  {% endif %}
  {{ sectionRule() }}
</section>
{% endmacro %}

{% macro emptySection(headingKey, emptyKey) %}
<section class="govuk-!-margin-top-6">
  <h2 class="govuk-heading-l">{{ localise('summary-log:enhanced.' + headingKey) }}</h2>
  {{ sectionRule() }}
  <p class="govuk-body">{{ localise('summary-log:enhanced.' + emptyKey) }}</p>
  {{ sectionRule() }}
</section>
{% endmacro %}

{% block content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <h1 class="govuk-heading-xl">
      <span class="govuk-caption-xl">{{ localise('summary-log:enhanced.pageCaption') }}</span>
      {{ localise('summary-log:enhanced.pageHeading') }}
    </h1>

    <p class="govuk-body">{{ localise('summary-log:checkIntro') }}</p>

    <div class="govuk-inset-text">
      <p class="govuk-body">{{ localise('summary-log:enhanced.insetSaveWarning') }}</p>
      <p class="govuk-body">
        <strong>{{ localise('summary-log:enhanced.insetWrongLead') }}</strong>
        {{ localise('summary-log:enhanced.insetEditAnd') }}
        <a href="/organisations/{{ organisationId }}/registrations/{{ registrationId }}/summary-logs/upload" class="govuk-link">{{ localise('summary-log:enhanced.insetChooseFileLink') }}</a>
        {{ localise('summary-log:enhanced.insetBeforeHome') }}
        <a href="/organisations/{{ organisationId }}" class="govuk-link">{{ localise('summary-log:enhanced.insetHomeLink') }}</a>).
      </p>
    </div>

    {% if isEmpty %}
      {{ emptySection('openNewLoadsHeading', 'emptyOpenNewLoads') }}
      {{ emptySection('openAdjustedLoadsHeading', 'emptyOpenAdjustedLoads') }}
      {{ emptySection('closedNewLoadsHeading', 'emptyClosedNewLoads') }}
      {{ emptySection('closedAdjustedLoadsHeading', 'emptyClosedAdjustedLoads') }}
    {% else %}
      {% if periodSections.open %}
        {% if periodSections.open.added %}
          {{ newLoadsSection(periodSections.open.added, 'openNewLoadsHeading', isAccredited) }}
        {% endif %}
        {% if periodSections.open.adjusted %}
          {{ adjustedLoadsSection(periodSections.open.adjusted, 'openAdjustedLoadsHeading', isAccredited, true) }}
        {% endif %}
      {% endif %}
      {% if periodSections.closed %}
        {% if periodSections.closed.added %}
          {{ newLoadsSection(periodSections.closed.added, 'closedNewLoadsHeading', isAccredited) }}
        {% endif %}
        {% if periodSections.closed.adjusted %}
          {{ adjustedLoadsSection(periodSections.closed.adjusted, 'closedAdjustedLoadsHeading', isAccredited, false) }}
        {% endif %}
      {% endif %}
    {% endif %}

    {% if wasteBalanceProjection %}
    <div class="epr-summary-log-projection govuk-!-margin-top-6">
      <p class="govuk-body">{{ localise('summary-log:enhanced.projectionPrefix') }} <strong>{{ wasteBalanceProjection.projected }}</strong> {{ localise('summary-log:enhanced.projectionSuffix', { current: wasteBalanceProjection.current }) }}</p>
    </div>
    {% endif %}

    <form class="govuk-!-margin-top-6" method="POST" action="/organisations/{{ organisationId }}/registrations/{{ registrationId }}/summary-logs/{{ summaryLogId }}/submit">
      <input type="hidden" name="crumb" value="{{ crumb }}" />
      <div class="govuk-button-group">
        {{ govukButton({
          text: localise('summary-log:enhanced.submitButton'),
          preventDoubleClick: true
        }) }}
        {{ govukButton({
          text: localise('summary-log:enhanced.goBackButton'),
          href: '/organisations/' + organisationId + '/registrations/' + registrationId + '/summary-logs/upload',
          classes: 'govuk-button--secondary'
        }) }}
      </div>
    </form>
  </div>
</div>
{% endblock %}
