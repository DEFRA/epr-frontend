{% extends 'layouts/page.njk' %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block beforeContent %}
  {{ govukBackLink({
    text: localise("common:back"),
    href: backUrl
  }) }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if errorSummary %}
        {{ govukErrorSummary({
          titleText: errorSummary.titleText,
          errorList: errorSummary.errorList
        }) }}
      {% endif %}

      <span class="govuk-caption-xl">{{ caption }}</span>
      <h1 class="govuk-heading-xl">{{ heading }}</h1>

      {% if insetText %}
        <div class="govuk-inset-text">{{ insetText }}</div>
      {% else %}
        <p class="govuk-hint">{{ hintText }}</p>
      {% endif %}

      <form method="POST" novalidate>
        <input type="hidden" name="crumb" value="{{ crumb }}" />

        {{ govukInput({
          id: fieldName,
          name: fieldName,
          inputmode: "decimal",
          spellcheck: false,
          classes: "govuk-input--width-5",
          suffix: {
            text: "tonnes"
          },
          label: {
            text: inputLabel if inputLabel else heading,
            classes: "govuk-label--m" if inputLabel else "govuk-visually-hidden"
          },
          hint: {
            text: inputHint
          } if inputHint else undefined,
          value: value,
          errorMessage: errors[fieldName] if errors else null
        }) }}

        <div class="govuk-button-group">
          {{ govukButton({
            text: continueText,
            name: "action",
            value: "continue"
          }) }}

          {{ govukButton({
            text: saveText,
            name: "action",
            value: "save",
            classes: "govuk-button--secondary"
          }) }}
        </div>

        <p class="govuk-body">
          <a href="{{ deleteUrl }}" class="govuk-link">{{ localise("reports:deleteReportLink") }}</a>
        </p>
      </form>

    </div>
  </div>
{% endblock %}
