{% extends 'layouts/page.njk' %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "overseas-sites-tables/macro.njk" import overseasSitesTables %}
{% from "tonnage-breakdown/macro.njk" import tonnageBreakdown %}
{% from "tonnage-total/macro.njk" import tonnageTotal %}

{% block beforeContent %}
  {{ govukBackLink({
    text: localise("common:back"),
    href: backUrl
  }) }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if errorSummary %}
        {{ govukErrorSummary({
          titleText: errorSummary.titleText,
          errorList: errorSummary.errorList
        }) }}
      {% endif %}

      <h1 class="govuk-heading-xl">{{ heading }}</h1>

      {{ govukInsetText({
        text: insetText
      }) }}

      <h2 class="govuk-heading-l">{{ localise("reports:submitDetailsHeading") }}</h2>

      <p class="govuk-body">
        <strong>{{ localise("reports:submitStatusLabel") }}</strong>
        {{ govukTag({ text: statusTag, classes: statusTagClass }) }}
      </p>
      <p class="govuk-body">
        <strong>{{ createdByLabel }}</strong> {{ createdBy }}
      </p>
      <p class="govuk-body">
        <strong>{{ createdOnLabel }}</strong> {{ createdOn }}
      </p>

      <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

      <h2 class="govuk-heading-l">{{ localise("reports:submitYourReportHeading") }}</h2>

      {% set yourReportRows = [
        { key: { text: localise("reports:periodColumn") }, value: { text: periodLabel } },
        { key: { text: localise("reports:materialLabel") }, value: { text: material } }
      ] %}
      {% if site %}
        {% set yourReportRows = yourReportRows.concat([{
          key: { text: localise("reports:siteLabel") },
          value: { text: site.address.line1 }
        }]) %}
      {% endif %}
      {{ govukSummaryList({ rows: yourReportRows }) }}

      <h2 class="govuk-heading-l">{{ wasteReceivedHeading }}</h2>

      {{ tonnageTotal(localise("reports:totalTonnageReceived"), wasteReceived.totalTonnage) }}

      {% if wasteReceived.supplierDetailRows | length > 0 %}
        <h3 class="govuk-heading-m">{{ localise("reports:suppliersHeading") }}</h3>
        {{ govukTable({
          head: [
            { text: localise("reports:supplierColumn") },
            { text: localise("reports:activityColumn") },
            { text: localise("reports:addressColumn") },
            { text: localise("reports:phoneColumn") },
            { text: localise("reports:emailColumn") }
          ],
          rows: wasteReceived.supplierDetailRows
        }) }}
      {% endif %}

      {% if isExporter %}

        <h2 class="govuk-heading-l">{{ localise("reports:wasteExportedHeading") }}</h2>

        {{ tonnageTotal(localise("reports:totalTonnageExported"), wasteExported.totalTonnage) }}

        {% set overseasSiteHead = [
            { text: localise("reports:siteNameColumn") },
            { text: localise("reports:osrIdColumn") },
            { text: localise("reports:countryColumn") }
        ] %}
        {% if showApprovalColumn %}
          {% set overseasSiteHead = overseasSiteHead.concat([{ text: localise("reports:approvedColumn") }]) %}
        {% endif %}
        {{ overseasSitesTables({
          approvedRows: wasteExported.overseasSiteRows,
          approvedHead: overseasSiteHead,
          approvedHeading: localise("reports:overseasSitesHeading"),
          unapprovedRows: wasteExported.unapprovedOverseasSiteRows,
          unapprovedHead: [{ text: localise("reports:unapprovedOrsIdColumn") }],
          unapprovedHeading: localise("reports:unapprovedOverseasSitesHeading"),
          unapprovedIntro: localise("reports:unapprovedOverseasSitesIntro")
        }) }}

        {% if isAccredited %}
          <h2 class="govuk-heading-l">{{ localise("reports:tonnageReceivedNotExportedHeading") }}</h2>

          {{ tonnageTotal(localise("reports:tonnageReceivedNotExportedLabel"), wasteExported.tonnageReceivedNotExported) }}
        {% endif %}

        <h2 class="govuk-heading-l">{{ localise("reports:tonnageRefusedOrStoppedHeading") }}</h2>

        {{ tonnageTotal(localise("reports:tonnageRefusedOrStoppedLabel"), wasteExported.tonnageRefusedOrStopped) }}

        {{ tonnageBreakdown([
          { key: "reports:tonnageRefusedLabel", value: wasteExported.tonnageRefused },
          { key: "reports:tonnageStoppedLabel", value: wasteExported.tonnageStopped },
          { key: "reports:tonnageRepatriatedLabel", value: wasteExported.tonnageRepatriated }
        ], localise) }}
      {% endif %}

      <h2 class="govuk-heading-l">{{ localise("reports:wasteSentOnHeading") }}</h2>

      {{ tonnageTotal(localise("reports:totalTonnageSentOn"), wasteSentOn.totalTonnage) }}

      {{ tonnageBreakdown([
        { key: "reports:tonnageSentOnToReprocessors", value: wasteSentOn.toReprocessors },
        { key: "reports:tonnageSentOnToExporters", value: wasteSentOn.toExporters },
        { key: "reports:tonnageSentOnToOtherSites", value: wasteSentOn.toOtherSites }
      ], localise) }}

      {% if wasteSentOn.destinationDetailRows | length > 0 %}
        <h3 class="govuk-heading-m">{{ localise("reports:destinationsHeading") }}</h3>
        {{ govukTable({
          head: [
            { text: localise("reports:recipientColumn") },
            { text: localise("reports:facilityTypeColumn") },
            { text: localise("reports:addressColumn") },
            { text: localise("reports:tonnageSentOnColumn") }
          ],
          rows: wasteSentOn.destinationDetailRows
        }) }}
      {% endif %}
      
      {% if isRegisteredOnlyExporter %}
        <h2 class="govuk-heading-l">{{ localise("reports:tonnageReceivedNotExportedHeading") }}</h2>

        {{ govukSummaryList({
          rows: [{
            key: { text: localise("reports:tonnageReceivedNotExportedRegOnlyLabel") },
            value: { text: wasteExported.tonnageReceivedNotExported }
          }]
        }) }}
      {% endif %}

      {% if isReprocessor %}
        <h2 class="govuk-heading-l">{{ localise("reports:submitRecyclingActivityHeading") }}</h2>

        {{ tonnageTotal(localise("reports:submitTotalTonnageRecycled"), recyclingActivity.tonnageRecycled) }}

        {{ govukSummaryList({
          rows: [
            {
              key: { text: localise("reports:submitTotalTonnageReceivedNotRecycled") },
              value: { text: recyclingActivity.tonnageNotRecycled }
            }
          ]
        }) }}

      {% endif %}

      {% if isAccredited %}
        <h2 class="govuk-heading-l">{{ noteTypeSectionHeading }}</h2>
        {{ tonnageTotal(totalIssuedTonnageLabel, prn.issuedTonnage | formatWholeNumberTonnage) }}

        {% set freeTonnageKey = freeLabel + '<br><span class="govuk-!-font-weight-regular">' + localise("reports:submitFreeTonnageNote") + '</span>' %}

        {{ govukSummaryList({
          rows: [
            {
              key: { html: freeTonnageKey },
              value: { text: prn.freeTonnage | formatWholeNumberTonnage }
            },
            {
              key: { text: revenueLabel },
              value: { text: prn.totalRevenue | formatCurrency }
            },
            {
              key: { text: avgPriceLabel },
              value: { text: prn.averagePricePerTonne | formatCurrency }
            }
          ]
        }) }}
      {% endif %}

      <h2 class="govuk-heading-l">{{ localise("reports:submitSupportingInformationHeading") }}</h2>

      {{ govukSummaryList({
        rows: [
          {
            key: { text: localise("reports:supportingInformationLabel") },
            value: { text: supportingInformation }
          }
        ]
      }) }}

      <h2 class="govuk-heading-l">{{ localise("reports:submitDeclarationHeading") }}</h2>

      <p class="govuk-body">{{ localise("reports:submitDeclarationText") }}</p>

      <ul class="govuk-list govuk-list--bullet">
        {% for item in declarationItems %}
          <li>{{ item }}</li>
        {% endfor %}
      </ul>

      <form method="POST" novalidate>
        <input type="hidden" name="crumb" value="{{ crumb }}" />
        <input type="hidden" name="version" value="{{ version }}" />

        {{ govukInput({
          label: {
            text: localise("reports:submitDeclarationFullNameLabel"),
            classes: "govuk-label--m"
          },
          hint: {
            text: localise("reports:submitDeclarationFullNameHint")
          },
          id: "submissionDeclaredBy",
          name: "submissionDeclaredBy",
          value: submissionDeclaredBy if submissionDeclaredBy else "",
          autocomplete: "name",
          spellcheck: false,
          errorMessage: errors.submissionDeclaredBy if errors else null
        }) }}

        <div class="govuk-button-group">
          {{ govukButton({
            text: localise("reports:submitButton"),
            preventDoubleClick: true
          }) }}

          {{ govukButton({
            text: localise("reports:deleteReportLink"),
            href: deleteUrl,
            classes: "govuk-button--warning"
          }) }}
        </div>
      </form>

    </div>
  </div>
{% endblock %}
