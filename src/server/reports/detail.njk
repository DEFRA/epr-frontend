{% extends 'layouts/page.njk' %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "overseas-sites-tables/macro.njk" import overseasSitesTables %}
{% from "tonnage-breakdown/macro.njk" import tonnageBreakdown %}
{% from "tonnage-total/macro.njk" import tonnageTotal %}

{% block beforeContent %}
  {{ govukBackLink({
    text: localise("common:back"),
    href: backUrl
  }) }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <span class="govuk-caption-xl">{{ localise("reports:checkCaption") }}</span>
      <h1 class="govuk-heading-xl">{{ heading }}</h1>

      {% if lastUploadedAt %}
        {{ govukInsetText({
          text: localise("reports:lastUploadedAt", { time: lastUploadedAt.time, date: lastUploadedAt.date })
        }) }}
      {% endif %}

      <p class="govuk-body">{{ localise("reports:overviewIntro", { periodLabel: periodLabel }) }}</p>

      <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

      <h2 class="govuk-heading-l">{{ localise("reports:detailsHeading") }}</h2>
      <p class="govuk-body">
        <strong>{{ localise("reports:accreditationLabel") if accreditation else localise("reports:registrationLabel") }}:</strong>
        {{ accreditation if accreditation else registrationNumber }}
      </p>
      <p class="govuk-body"><strong>{{ localise("reports:materialLabel") }}:</strong> {{ material }}</p>
      {% if site %}
        <p class="govuk-body"><strong>{{ localise("reports:siteLabel") }}:</strong> {{ site.address.line1 }}</p>
      {% endif %}
      <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

      <h2 class="govuk-heading-l">{{ wasteReceivedHeading }}</h2>
      {% if isExporter %}
        <p class="govuk-body">{{ wasteReceivedForExportIntro }}</p>
      {% else %}
        <p class="govuk-body">{{ wasteReceivedIntroReprocessor }}</p>
      {% endif %}

      {{ tonnageTotal(localise("reports:totalTonnageReceived"), wasteReceived.totalTonnage) }}

      {% if wasteReceived.supplierRows | length > 0 %}
        <h3 class="govuk-heading-m">{{ localise("reports:suppliersHeading") }}</h3>
        {{ govukTable({
          head: [
            { text: localise("reports:supplierColumn") },
            { text: localise("reports:activityColumn") },
            { text: localise("reports:tonnageReceivedColumn") }
          ],
          rows: wasteReceived.supplierRows
        }) }}
      {% endif %}

      {% if isExporter %}
        <h2 class="govuk-heading-l">{{ localise("reports:wasteExportedHeading") }}</h2>
        <p class="govuk-body">{{ wasteExportedIntro }}</p>

        {{ tonnageTotal(localise("reports:totalTonnageExported"), wasteExported.totalTonnage) }}

        <div class="govuk-inset-text">
          <p class="govuk-body">{{ localise("reports:orsHelpLine1") }}</p>
          <p class="govuk-body">{{ localise("reports:orsHelpLine2") }}</p>
        </div>

        {% set overseasSiteHead = [
            { text: localise("reports:siteNameColumn") },
            { text: localise("reports:tonnageExportedColumn") },
            { text: localise("reports:osrIdColumn") },
            { text: localise("reports:countryColumn") }
        ] %}
        {% if showApprovalColumn %}
          {% set overseasSiteHead = overseasSiteHead.concat([{ text: localise("reports:approvedColumn") }]) %}
        {% endif %}
        {{ overseasSitesTables({
          approvedRows: wasteExported.overseasSiteDetailRows,
          approvedHead: overseasSiteHead,
          approvedHeading: localise("reports:overseasSitesHeading"),
          unapprovedRows: wasteExported.unapprovedOverseasSiteDetailRows,
          unapprovedHead: [
            { text: localise("reports:tonnageExportedColumn") },
            { text: localise("reports:unapprovedOrsIdColumn") }
          ],
          unapprovedHeading: localise("reports:unapprovedOverseasSitesHeading"),
          unapprovedIntro: localise("reports:unapprovedOverseasSitesIntro")
        }) }}

        {% if not isRegisteredOnlyExporter %}
          <h2 class="govuk-heading-l">{{ localise("reports:tonnageReceivedNotExportedHeading") }}</h2>
          <p class="govuk-body">{{ tonnageReceivedNotExportedIntro }}</p>

          {{ tonnageTotal(localise("reports:tonnageReceivedNotExportedLabel"), wasteExported.tonnageReceivedNotExported) }}

          <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">
        {% endif %}

        <h2 class="govuk-heading-l">{{ localise("reports:tonnageRefusedOrStoppedHeading") }}</h2>
        <p class="govuk-body">{{ tonnageRefusedOrStoppedIntro }}</p>

        {{ tonnageTotal(localise("reports:tonnageRefusedOrStoppedLabel"), wasteExported.tonnageRefusedOrStopped) }}

        {{ tonnageBreakdown([
          { key: "reports:tonnageRefusedLabel", value: wasteExported.tonnageRefused },
          { key: "reports:tonnageStoppedLabel", value: wasteExported.tonnageStopped },
          { key: "reports:tonnageRepatriatedLabel", value: wasteExported.tonnageRepatriated }
        ], localise) }}
      {% endif %}

      <h2 class="govuk-heading-l">{{ localise("reports:wasteSentOnHeading") }}</h2>
      {% if isExporter %}
        <p class="govuk-body">{{ wasteSentOnIntroExporter }}</p>
      {% else %}
        <p class="govuk-body">{{ wasteSentOnIntroReprocessor }}</p>
      {% endif %}

      {{ tonnageTotal(localise("reports:totalTonnageSentOn"), wasteSentOn.totalTonnage) }}

      {{ tonnageBreakdown([
        { key: "reports:tonnageSentOnToReprocessors", value: wasteSentOn.toReprocessors },
        { key: "reports:tonnageSentOnToExporters", value: wasteSentOn.toExporters },
        { key: "reports:tonnageSentOnToOtherSites", value: wasteSentOn.toOtherSites }
      ], localise) }}

      {% if wasteSentOn.destinationRows | length > 0 %}
        <h3 class="govuk-heading-m">{{ localise("reports:destinationsHeading") }}</h3>
        {{ govukTable({
          head: [
            { text: localise("reports:recipientColumn") },
            { text: localise("reports:activityColumn") },
            { text: localise("reports:tonnageSentOnColumn") }
          ],
          rows: wasteSentOn.destinationRows
        }) }}
      {% endif %}

      <form method="POST" novalidate>
        <input type="hidden" name="crumb" value="{{ crumb }}" />
        {{ govukButton({
          text: localise("reports:useThisData"),
          preventDoubleClick: true
        }) }}
        {{ govukButton({
          text: localise("reports:uploadNewSummaryLog"),
          href: uploadUrl,
          classes: "govuk-button--secondary"
        }) }}
      </form>
      <p class="govuk-body">
        <a href="{{ backUrl }}" class="govuk-link">{{ localise("reports:cancelAndReturn") }}</a>
      </p>

    </div>
  </div>
{% endblock %}
