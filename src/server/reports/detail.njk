{% extends 'layouts/page.njk' %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "govuk/components/table/macro.njk" import govukTable %}

{% block beforeContent %}
  {{ govukBackLink({
    text: localise("common:back"),
    href: backUrl
  }) }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <span class="govuk-caption-l">{{ material }}</span>
      <h1 class="govuk-heading-l">{{ heading }}</h1>

      <p class="govuk-body">{{ localise("reports:overviewIntro", { periodLabel: periodLabel }) }}</p>

      {% if lastUploadedAt %}
        {{ govukInsetText({
          text: localise("reports:lastUploadedAt", { time: lastUploadedAt.time, date: lastUploadedAt.date })
        }) }}

        <p class="govuk-body">
          {{ localise("reports:correctionPrefix") }}
          <a href="{{ uploadUrl }}" class="govuk-link">{{ localise("reports:correctionLink") }}</a>
          {{ localise("reports:correctionSuffix") }}
        </p>
      {% endif %}

      <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

      {% if accreditation or site %}
        <h2 class="govuk-heading-m">{{ localise("reports:detailsHeading") }}</h2>
        {% if accreditation %}
          <p class="govuk-body"><strong>{{ localise("reports:accreditationLabel") }}:</strong> {{ accreditation }}</p>
        {% endif %}
        <p class="govuk-body"><strong>{{ localise("reports:materialLabel") }}:</strong> {{ material }}</p>
        {% if site %}
          <p class="govuk-body"><strong>{{ localise("reports:siteLabel") }}:</strong> {{ site.address.line1 }}</p>
        {% endif %}
        <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">
      {% endif %}

      {% if isExporter %}
        <h2 class="govuk-heading-m">{{ localise("reports:wasteReceivedForExportHeading") }}</h2>
        <p class="govuk-body">{{ localise("reports:wasteReceivedForExportIntro") }}</p>
      {% else %}
        <h2 class="govuk-heading-m">{{ localise("reports:wasteReceivedHeading") }}</h2>
        <p class="govuk-body">{{ localise("reports:wasteReceivedIntro") }}</p>
      {% endif %}

      <p class="govuk-body-s govuk-!-margin-bottom-1">{{ localise("reports:totalTonnageReceived") }}</p>
      <p class="govuk-heading-m">{{ wasteReceived.totalTonnage }}</p>

      {% if wasteReceived.supplierRows | length > 0 %}
        <h3 class="govuk-heading-s">{{ localise("reports:supplierDetailsHeading") }}</h3>
        {{ govukTable({
          head: [
            { text: localise("reports:supplierColumn") },
            { text: localise("reports:roleColumn") },
            { text: localise("reports:tonnageReceivedColumn") }
          ],
          rows: wasteReceived.supplierRows
        }) }}
      {% endif %}

      {% if wasteExported %}
        <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

        <h2 class="govuk-heading-m">{{ localise("reports:wasteExportedHeading") }}</h2>
        <p class="govuk-body">{{ localise("reports:wasteExportedIntro") }}</p>

        <p class="govuk-body-s govuk-!-margin-bottom-1">{{ localise("reports:totalTonnageExported") }}</p>
        <p class="govuk-heading-m">{{ wasteExported.totalTonnage }}</p>

        {% if wasteExported.overseasSiteRows | length > 0 %}
          <h3 class="govuk-heading-s">{{ localise("reports:overseasSitesHeading") }}</h3>
          {{ govukTable({
            head: [
              { text: localise("reports:siteNameColumn") },
              { text: localise("reports:osrIdColumn") }
            ],
            rows: wasteExported.overseasSiteRows
          }) }}
        {% endif %}
      {% endif %}

      <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

      <h2 class="govuk-heading-m">{{ localise("reports:wasteSentOnHeading") }}</h2>
      <p class="govuk-body">{{ localise("reports:wasteSentOnIntro") }}</p>

      <p class="govuk-body-s govuk-!-margin-bottom-1">{{ localise("reports:totalTonnageSentOn") }}</p>
      <p class="govuk-heading-m">{{ wasteSentOn.totalTonnage }}</p>

      {{ govukTable({
        rows: [
          [{ text: localise("reports:tonnageSentOnToReprocessors") }, { text: wasteSentOn.toReprocessors }],
          [{ text: localise("reports:tonnageSentOnToExporters") }, { text: wasteSentOn.toExporters }],
          [{ text: localise("reports:tonnageSentOnToOtherSites") }, { text: wasteSentOn.toOtherSites }]
        ]
      }) }}

      {% if wasteSentOn.destinationRows | length > 0 %}
        <h3 class="govuk-heading-s">{{ localise("reports:destinationHeading") }}</h3>
        {{ govukTable({
          head: [
            { text: localise("reports:recipientColumn") },
            { text: localise("reports:roleColumn") },
            { text: localise("reports:tonnageSentOnColumn") }
          ],
          rows: wasteSentOn.destinationRows
        }) }}
      {% endif %}

      <form method="POST" novalidate>
        <input type="hidden" name="crumb" value="{{ crumb }}" />
        {{ govukButton({
          text: localise("reports:useThisData")
        }) }}
      </form>

    </div>
  </div>
{% endblock %}
