{% extends 'layouts/page.njk' %}

{% block content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <div class="govuk-panel govuk-panel--confirmation">
      <h1 class="govuk-panel__title">
        {{ heading }}
      </h1>
      <div class="govuk-panel__body">
        {{ statusLabel }}<br>
        <strong>{{ statusValue }}</strong>
      </div>
    </div>

    <h2 class="govuk-heading-m">{{ detailsHeading }}</h2>

    <p class="govuk-body">
      <strong>{{ registrationLabel }}</strong> {{ registrationNumber }}
    </p>

    <p class="govuk-body">
      <strong>{{ materialLabel }}</strong> {{ material }}
    </p>

    <h2 class="govuk-heading-m">{{ nextStepsHeading }}</h2>

    <p class="govuk-body">
      {{ nextStepsGuidance }}
    </p>

    <p class="govuk-body">
      {{ selfSubmitGuidance }}
    </p>

    <div class="govuk-button-group">
      <a href="{{ goToReportsButton.href }}" role="button" draggable="false" class="govuk-button" data-module="govuk-button">
        {{ goToReportsButton.text }}
      </a>
      <a href="{{ viewDraftReportLink.href }}" role="button" draggable="false" class="govuk-button govuk-button--secondary" data-module="govuk-button" target="_blank" rel="noopener noreferrer">
        {{ viewDraftReportLink.text }}
      </a>
    </div>

    <p class="govuk-body">
      <a href="{{ returnHomeLink.href }}" class="govuk-link">{{ returnHomeLink.text }}</a>
    </p>
  </div>
</div>
{% endblock %}
