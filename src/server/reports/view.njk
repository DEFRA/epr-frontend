{% extends 'layouts/page.njk' %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "overseas-sites-tables/macro.njk" import overseasSitesTables %}
{% from "tonnage-breakdown/macro.njk" import tonnageBreakdown %}
{% from "report-section/macro.njk" import reportSection %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{% block beforeContent %}
  {% if backUrl %}
    {{ govukBackLink({
      text: localise("common:back"),
      href: backUrl
    }) }}
  {% endif %}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">{{ heading }}</h1>

      {% if isDraft %}
        <p class="govuk-body">{{ introText }}</p>
        <p class="govuk-body">
          {{ localise("reports:view:draftSelfSubmitPrefix") }}
          <a href="{{ reportsUrl }}" class="govuk-link">{{ localise("reports:view:draftSelfSubmitLink") }}</a>.
        </p>
      {% endif %}

      <div id="submission-details">
        <h2 class="govuk-heading-l">{{ localise("reports:view:detailsHeading") }}</h2>

        <p class="govuk-body">
          <strong>{{ localise("reports:view:statusLabel") }}</strong>
          {{ govukTag({ text: statusTag, classes: statusTagClass }) }}
        </p>
        <p class="govuk-body">
          <strong>{{ authorLabel }}</strong> {{ authorValue }}
        </p>
        <p class="govuk-body">
          <strong>{{ dateLabel }}</strong> {{ dateValue }}
        </p>
      </div>

      <hr class="govuk-section-break govuk-section-break--l">

      {% if isDraft %}
        <h2 class="govuk-heading-l">{{ localise("reports:view:draftYourReportHeading") }}</h2>
      {% endif %}

      <div id="report-period">
        {{ govukSummaryList({
          rows: [
            {
              key: { text: localise("reports:periodColumn") },
              value: { text: periodLabel }
            },
            {
              key: { text: localise("reports:materialLabel") },
              value: { text: material }
            }
          ].concat([
            {
              key: { text: localise("reports:siteLabel") },
              value: { text: site }
            }
          ] if site else [])
        }) }}
      </div>

      {% if isReprocessor %}
        <div id="waste-received-for-reprocessing">
          {{ reportSection(wasteReceivedHeading, localise("reports:totalTonnageReceived"), wasteReceived.totalTonnage) }}

          {% if wasteReceived.supplierDetailRows | length > 0 %}
            <h3 class="govuk-heading-m">{{ localise("reports:suppliersHeading") }}</h3>
            {{ govukTable({
              head: [
                { text: localise("reports:supplierColumn") },
                { text: localise("reports:activityColumn") },
                { text: localise("reports:addressColumn") },
                { text: localise("reports:phoneColumn") },
                { text: localise("reports:emailColumn") }
              ],
              rows: wasteReceived.supplierDetailRows
            }) }}
          {% endif %}
        </div>

        <div id="packaging-waste-recycling">
          {{ reportSection(localise("reports:view:recyclingActivityHeading"), localise("reports:view:totalTonnageRecycled"), packagingWasteRecycling.tonnageRecycled) }}

          {{ govukSummaryList({
            rows: [
              {
                key: { text: localise("reports:view:totalTonnageReceivedNotRecycled") },
                value: { text: packagingWasteRecycling.tonnageNotRecycled }
              }
            ]
          }) }}
        </div>
      {% endif %}

      {% if isExporter %}
        <div id="waste-received-for-exporting">
          {{ reportSection(wasteReceivedHeading, localise("reports:totalTonnageReceived"), wasteReceived.totalTonnage) }}

          {% if wasteReceived.supplierDetailRows | length > 0 %}
            <h3 class="govuk-heading-m">{{ localise("reports:suppliersHeading") }}</h3>
            {{ govukTable({
              head: [
                { text: localise("reports:supplierColumn") },
                { text: localise("reports:activityColumn") },
                { text: localise("reports:addressColumn") },
                { text: localise("reports:phoneColumn") },
                { text: localise("reports:emailColumn") }
              ],
              rows: wasteReceived.supplierDetailRows
            }) }}
          {% endif %}
        </div>
      {% endif %}

      {% if isExporter %}
        <div id="waste-exported-for-recycling">
          {{ reportSection(localise("reports:wasteExportedHeading"), localise("reports:totalTonnageExported"), wasteExported.totalTonnage) }}

          {% set overseasSiteHead = [
              { text: localise("reports:siteNameColumn") },
              { text: localise("reports:osrIdColumn") },
              { text: localise("reports:countryColumn") }
          ] %}
          {% if isAccredited %}
            {% set overseasSiteHead = overseasSiteHead.concat([{ text: localise("reports:approvedColumn") }]) %}
          {% endif %}
          {{ overseasSitesTables({
            approvedRows: wasteExported.overseasSiteRows,
            approvedHead: overseasSiteHead,
            approvedHeading: localise("reports:overseasSitesHeading"),
            unapprovedRows: wasteExported.unapprovedOverseasSiteRows,
            unapprovedHead: [{ text: localise("reports:unapprovedOrsIdColumn") }],
            unapprovedHeading: localise("reports:unapprovedOverseasSitesHeading"),
            unapprovedIntro: localise("reports:unapprovedOverseasSitesIntro")
          }) }}
        </div>

        {% if isAccredited %}
          <div id="waste-received-but-not-exported">
            {{ reportSection(localise("reports:tonnageReceivedNotExportedHeading"), localise("reports:tonnageReceivedNotExportedLabel"), wasteExported.tonnageReceivedNotExported) }}
          </div>
        {% endif %}

        <div id="packaging-waste-refused-or-stopped-during-export">
          {{ reportSection(localise("reports:tonnageRefusedOrStoppedHeading"), localise("reports:tonnageRefusedOrStoppedLabel"), wasteExported.tonnageRefusedOrStopped) }}

          {{ tonnageBreakdown([
            { key: "reports:tonnageRefusedLabel", value: wasteExported.tonnageRefused },
            { key: "reports:tonnageStoppedLabel", value: wasteExported.tonnageStopped },
            { key: "reports:tonnageRepatriatedLabel", value: wasteExported.tonnageRepatriated }
          ], localise) }}
        </div>
      {% endif %}

      <div id="packaging-waste-sent-on">
        {{ reportSection(localise("reports:wasteSentOnHeading"), localise("reports:totalTonnageSentOn"), wasteSentOn.totalTonnage) }}

        {{ tonnageBreakdown([
          { key: "reports:tonnageSentOnToReprocessors", value: wasteSentOn.toReprocessors },
          { key: "reports:tonnageSentOnToExporters", value: wasteSentOn.toExporters },
          { key: "reports:tonnageSentOnToOtherSites", value: wasteSentOn.toOtherSites }
        ], localise) }}

        {% if wasteSentOn.destinationDetailRows | length > 0 %}
          {{ govukTable({
            caption: localise("reports:destinationsHeading"),
            captionClasses: "govuk-heading-m",
            head: [
              { text: localise("reports:recipientColumn") },
              { text: localise("reports:facilityTypeColumn") },
              { text: localise("reports:addressColumn") },
              { text: localise("reports:tonnageSentOnColumn") }
            ],
            rows: wasteSentOn.destinationDetailRows
          }) }}
        {% endif %}
      </div>

      {% if isRegisteredOnlyExporter %}
        <div id="waste-received-but-not-exported">
          <h2 class="govuk-heading-l">{{ localise("reports:tonnageReceivedNotExportedHeading") }}</h2>

          {{ govukSummaryList({
            rows: [{
              key: { text: localise("reports:tonnageReceivedNotExportedRegOnlyLabel") },
              value: { text: wasteExported.tonnageReceivedNotExported }
            }]
          }) }}
        </div>
      {% endif %}

      {% if isAccredited %}
        <div id="prns">
          {{ reportSection(noteTypeSectionHeading, totalIssuedTonnageLabel, prn.issuedTonnage | formatWholeNumberTonnage) }}

          {% set freeKeyHtml %}
            {{ freeLabel }}
            <span class="govuk-body-s govuk-!-font-weight-regular govuk-!-display-block govuk-!-margin-top-1">{{ localise("reports:freeTonnageNote") }}</span>
          {% endset %}

          {{ govukSummaryList({
            classes: "epr-summary-list--wide-key",
            rows: [
              {
                key: { text: revenueLabel },
                value: { text: prn.totalRevenue | formatCurrency }
              },
              {
                key: { html: freeKeyHtml },
                value: { text: prn.freeTonnage | formatWholeNumberTonnage }
              },
              {
                key: { text: avgPriceLabel },
                value: { text: prn.averagePricePerTonne | formatCurrency }
              }
            ]
          }) }}
        </div>
      {% endif %}

      <div id="supporting-information">
        <h2 class="govuk-heading-l">{{ localise("reports:view:supportingInformationHeading") }}</h2>

        {{ govukSummaryList({
          classes: "epr-summary-list--wide-key",
          rows: [
            {
              key: { text: localise("reports:supportingInformationLabel") },
              value: { text: supportingInformation }
            }
          ]
        }) }}
      </div>
    </div>
  </div>
{% endblock %}
