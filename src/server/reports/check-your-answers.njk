{% extends 'layouts/page.njk' %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "overseas-sites-tables/macro.njk" import overseasSitesTables %}
{% from "tonnage-breakdown/macro.njk" import tonnageBreakdown %}
{% from "report-section/macro.njk" import reportSubSection %}

{% block beforeContent %}
  {{ govukBackLink({
    text: localise("common:back"),
    href: backUrl
  }) }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <span class="govuk-caption-xl">{{ caption }}</span>
      <h1 class="govuk-heading-xl">{{ heading }}</h1>

      {{ govukSummaryList({
        rows: [
          {
            key: { text: localise("reports:periodColumn") },
            value: { text: periodLabel }
          },
          {
            key: { text: localise("reports:accreditationLabel") if isAccredited else localise("reports:registrationLabel") },
            value: { text: accreditationNumber if isAccredited else registrationNumber }
          },
          {
            key: { text: localise("reports:materialLabel") },
            value: { text: material }
          }
        ].concat([{
          key: { text: localise("reports:siteLabel") },
          value: { text: site.address.line1 }
        }] if site else [])
      }) }}

      <h2 class="govuk-heading-l">{{ localise("reports:checkSummaryLogDataHeading") }}</h2>
      {{ govukInsetText({
        text: localise("reports:checkSummaryLogDataGuidance")
      }) }}

      {{ reportSubSection(wasteReceivedHeading, localise("reports:totalTonnageReceived"), wasteReceived.totalTonnage) }}

      {% if wasteReceived.supplierDetailRows | length > 0 %}
        {{ govukTable({
          head: [
            { text: localise("reports:supplierColumn") },
            { text: localise("reports:activityColumn") },
            { text: localise("reports:addressColumn") },
            { text: localise("reports:phoneColumn") },
            { text: localise("reports:emailColumn") }
          ],
          rows: wasteReceived.supplierDetailRows
        }) }}
      {% endif %}

      {% if isExporter %}
        {{ reportSubSection(localise("reports:wasteExportedHeading"), localise("reports:totalTonnageExported"), wasteExported.totalTonnage) }}

        {% set overseasSiteHead = [
            { text: localise("reports:siteNameColumn") },
            { text: localise("reports:osrIdColumn") },
            { text: localise("reports:countryColumn") }
        ] %}
        {% if showApprovalColumn %}
          {% set overseasSiteHead = overseasSiteHead.concat([{ text: localise("reports:approvedColumn") }]) %}
        {% endif %}
        {{ overseasSitesTables({
          approvedRows: wasteExported.overseasSiteRows,
          approvedHead: overseasSiteHead,
          approvedHeading: localise("reports:overseasSitesHeading"),
          unapprovedRows: wasteExported.unapprovedOverseasSiteRows,
          unapprovedHead: [{ text: localise("reports:unapprovedOrsIdColumn") }],
          unapprovedHeading: localise("reports:unapprovedOverseasSitesHeading"),
          unapprovedIntro: localise("reports:unapprovedOverseasSitesIntro")
        }) }}

        {% if isAccredited %}
          {{ reportSubSection(localise("reports:tonnageReceivedNotExportedHeading"), localise("reports:tonnageReceivedNotExportedLabel"), wasteExported.tonnageReceivedNotExported) }}
        {% endif %}

        {{ reportSubSection(localise("reports:tonnageRefusedOrStoppedHeading"), localise("reports:tonnageRefusedOrStoppedLabel"), wasteExported.tonnageRefusedOrStopped) }}

        {{ tonnageBreakdown([
          { key: "reports:tonnageRefusedLabel", value: wasteExported.tonnageRefused },
          { key: "reports:tonnageStoppedLabel", value: wasteExported.tonnageStopped },
          { key: "reports:tonnageRepatriatedLabel", value: wasteExported.tonnageRepatriated }
        ], localise) }}
      {% endif %}

      {{ reportSubSection(localise("reports:wasteSentOnHeading"), localise("reports:totalTonnageSentOn"), wasteSentOn.totalTonnage) }}

      {{ tonnageBreakdown([
        { key: "reports:tonnageSentOnToReprocessors", value: wasteSentOn.toReprocessors },
        { key: "reports:tonnageSentOnToExporters", value: wasteSentOn.toExporters },
        { key: "reports:tonnageSentOnToOtherSites", value: wasteSentOn.toOtherSites }
      ], localise) }}

      {% if wasteSentOn.destinationDetailRows | length > 0 %}
          {{ govukTable({
            head: [
              { text: localise("reports:recipientColumn") },
              { text: localise("reports:activityColumn") },
              { text: localise("reports:addressColumn") },
              { text: localise("reports:tonnageSentOnColumn") }
            ],
            rows: wasteSentOn.destinationDetailRows
          }) }}
      {% endif %}

      {% if isRegisteredOnlyExporter %}
        <h2 class="govuk-heading-l">{{ localise("reports:tonnageReceivedNotExportedHeading") }}</h2>

        {{ govukSummaryList({
          rows: [{
            key: { text: localise("reports:tonnageReceivedNotExportedRegOnlyLabel") },
            value: { text: wasteExported.tonnageReceivedNotExported },
            actions: { items: [{ href: tonnageNotExportedChangeUrl, text: changeText, visuallyHiddenText: localise("reports:tonnageReceivedNotExportedRegOnlyLabel") }] }
          }]
        }) }}
      {% endif %}

      {% if isReprocessor %}

        <h2 class="govuk-heading-l">{{ localise("reports:checkRecyclingActivityHeading") }}</h2>

        {{ govukSummaryList({
          rows: [
            {
              key: { text: localise("reports:checkTonnageRecycledLabel") },
              value: { text: recyclingActivity.tonnageRecycled if recyclingActivity.tonnageRecycled !== null else "—" },
              actions: {
                items: [{
                  href: tonnageRecycledChangeUrl,
                  text: changeText,
                  visuallyHiddenText: localise("reports:checkTonnageRecycledLabel")
                }]
              }
            },
            {
              key: { text: localise("reports:checkTonnageNotRecycledLabel") },
              value: { text: recyclingActivity.tonnageNotRecycled if recyclingActivity.tonnageNotRecycled !== null else "—" },
              actions: {
                items: [{
                  href: tonnageNotRecycledChangeUrl,
                  text: changeText,
                  visuallyHiddenText: localise("reports:checkTonnageNotRecycledLabel")
                }]
              }
            }
          ]
        }) }}
      {% endif %}

      {% if prn and (isExporter or (isReprocessor and isAccredited)) %}

        <h3 class="govuk-heading-m">{{ noteTypeSectionHeading }}</h3>

        {% set prnRows = [
          {
            key: { text: totalIssuedTonnageLabel },
            value: { text: prn.issuedTonnage | formatWholeNumberTonnage }
          }
        ] %}

        {% if prn.totalRevenue is defined and prn.totalRevenue !== null %}
          {% set prnRows = prnRows.concat([{
            key: { text: revenueLabel },
            value: { text: prn.totalRevenue | formatCurrency },
            actions: {
              items: [{
                href: prnRevenueChangeUrl,
                text: changeText,
                visuallyHiddenText: revenueLabel
              }]
            }
          }]) %}
        {% endif %}

        {% if prn.freeTonnage is defined and prn.freeTonnage !== null %}
          {% set freeTonnageHtml %}
            {{ prn.freeTonnage }}
            <p class="govuk-body-s govuk-!-margin-top-1 govuk-!-margin-bottom-0">{{ freeNote }}</p>
          {% endset %}
          {% set freeTonnageChangeUrl = freePrnsChangeUrl if isReprocessor else freePernChangeUrl %}
          {% set prnRows = prnRows.concat([{
            key: { text: freeLabel },
            value: { html: freeTonnageHtml },
            actions: {
              items: [{
                href: freeTonnageChangeUrl,
                text: changeText,
                visuallyHiddenText: freeLabel
              }]
            }
          }]) %}
        {% endif %}

        {% if prn.averagePricePerTonne is defined and prn.averagePricePerTonne !== null %}
          {% set prnRows = prnRows.concat([{
            key: { text: localise("reports:checkAvgPriceLabel") },
            value: { text: prn.averagePricePerTonne | formatCurrency }
          }]) %}
        {% endif %}

        {{ govukSummaryList({ rows: prnRows }) }}
      {% endif %}

      <h2 class="govuk-heading-l">{{ localise("reports:checkSupportingInformationHeading") }}</h2>

      {{ govukSummaryList({
        rows: [
          {
            key: { text: supportingInformationLabel },
            value: { text: supportingInformation },
            actions: {
              items: [
                {
                  href: changeUrl,
                  text: changeText,
                  visuallyHiddenText: supportingInformationLabel
                }
              ]
            }
          }
        ]
      }) }}

      <h2 class="govuk-heading-l">{{ localise("reports:checkPleaseBeAwareHeading") }}</h2>
      <p class="govuk-body govuk-!-margin-bottom-8">{{ localise("reports:checkPleaseBeAwareText") }}</p>

      <form method="POST" novalidate>
        <input type="hidden" name="crumb" value="{{ crumb }}" />
        <input type="hidden" name="version" value="{{ version }}" />

        {{ govukButton({
          text: createButtonText,
          preventDoubleClick: true
        }) }}

        {{ govukButton({
          text: localise("reports:deleteAndStartAgainLink"),
          href: deleteUrl,
          classes: "govuk-button--warning"
        }) }}
      </form>

    </div>
  </div>
{% endblock %}
