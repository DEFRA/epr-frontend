{% extends 'layouts/page.njk' %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/table/macro.njk" import govukTable %}

{% block beforeContent %}
  {{ govukBackLink({
    text: localise("common:back"),
    href: backUrl
  }) }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <span class="govuk-caption-xl">{{ caption }}</span>
      <h1 class="govuk-heading-xl">{{ heading }}</h1>

      {{ govukSummaryList({
        rows: [
          {
            key: { text: localise("reports:periodColumn") },
            value: { text: cadenceLabel }
          },
          {
            key: { text: localise("reports:registrationLabel") },
            value: { text: registrationNumber }
          },
          {
            key: { text: localise("reports:materialLabel") },
            value: { text: material }
          }
        ]
      }) }}

      <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

      <h2 class="govuk-heading-l">{{ localise("reports:checkSummaryLogDataHeading") }}</h2>
      {{ govukInsetText({
        text: localise("reports:checkSummaryLogDataGuidance")
      }) }}

      {% if isExporter %}
        <h3 class="govuk-heading-m">{{ localise("reports:wasteReceivedForExportHeading") }}</h3>
      {% else %}
        <h3 class="govuk-heading-m">{{ localise("reports:wasteReceivedHeading") }}</h3>
      {% endif %}

      <p class="govuk-body-s govuk-!-margin-bottom-1">{{ localise("reports:totalTonnageReceived") }}</p>
      <p class="govuk-heading-m">{{ wasteReceived.totalTonnage }}</p>

      {% if wasteReceived.supplierDetailRows | length > 0 %}
        <h4 class="govuk-heading-s">{{ localise("reports:supplierDetailsHeading") }}</h4>
        {{ govukTable({
          head: [
            { text: localise("reports:supplierColumn") },
            { text: localise("reports:activityColumn") },
            { text: localise("reports:addressColumn") },
            { text: localise("reports:phoneColumn") },
            { text: localise("reports:emailColumn") }
          ],
          rows: wasteReceived.supplierDetailRows
        }) }}
      {% endif %}

      {% if wasteExported %}
        <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

        <h3 class="govuk-heading-m">{{ localise("reports:wasteExportedHeading") }}</h3>

        <p class="govuk-body-s govuk-!-margin-bottom-1">{{ localise("reports:totalTonnageExported") }}</p>
        <p class="govuk-heading-m">{{ wasteExported.totalTonnage }}</p>

        {% if wasteExported.overseasSiteRows | length > 0 %}
          <h4 class="govuk-heading-s">{{ localise("reports:overseasSitesHeading") }}</h4>
          {{ govukTable({
            head: [
              { text: localise("reports:siteNameColumn") },
              { text: localise("reports:osrIdColumn") }
            ],
            rows: wasteExported.overseasSiteRows
          }) }}
        {% endif %}

        <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

        <h3 class="govuk-heading-m">{{ localise("reports:tonnageReceivedNotExportedHeading") }}</h3>

        <p class="govuk-body-s govuk-!-margin-bottom-1">{{ localise("reports:tonnageReceivedNotExportedLabel") }}</p>
        <p class="govuk-heading-m">{{ wasteExported.tonnageReceivedNotExported }}</p>

        <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

        <h3 class="govuk-heading-m">{{ localise("reports:tonnageRefusedOrStoppedHeading") }}</h3>

        <p class="govuk-body-s govuk-!-margin-bottom-1">{{ localise("reports:tonnageRefusedOrStoppedLabel") }}</p>
        <p class="govuk-heading-m">{{ wasteExported.tonnageRefusedOrStopped }}</p>

        {{ govukTable({
          rows: [
            [{ text: localise("reports:tonnageRefusedLabel") }, { text: wasteExported.tonnageRefused }],
            [{ text: localise("reports:tonnageStoppedLabel") }, { text: wasteExported.tonnageStopped }],
            [{ text: localise("reports:tonnageRepatriatedLabel") }, { text: wasteExported.tonnageRepatriated }]
          ]
        }) }}
      {% endif %}

      <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

      <h3 class="govuk-heading-m">{{ localise("reports:wasteSentOnHeading") }}</h3>

      <p class="govuk-body-s govuk-!-margin-bottom-1">{{ localise("reports:totalTonnageSentOn") }}</p>
      <p class="govuk-heading-m">{{ wasteSentOn.totalTonnage }}</p>

      {{ govukTable({
        rows: [
          [{ text: localise("reports:tonnageSentOnToReprocessors") }, { text: wasteSentOn.toReprocessors }],
          [{ text: localise("reports:tonnageSentOnToExporters") }, { text: wasteSentOn.toExporters }],
          [{ text: localise("reports:tonnageSentOnToOtherSites") }, { text: wasteSentOn.toOtherSites }]
        ]
      }) }}

      {% if wasteSentOn.destinationDetailRows | length > 0 %}
        <h4 class="govuk-heading-s">{{ localise("reports:destinationHeading") }}</h4>
        {{ govukTable({
          head: [
            { text: localise("reports:recipientColumn") },
            { text: localise("reports:facilityTypeColumn") },
            { text: localise("reports:addressColumn") },
            { text: localise("reports:tonnageSentOnColumn") }
          ],
          rows: wasteSentOn.destinationDetailRows
        }) }}
      {% endif %}

      {% if prn %}
        <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

        {% if isExporter %}
          <h3 class="govuk-heading-m">{{ localise("reports:pernSectionHeading") }}</h3>
        {% else %}
          <h3 class="govuk-heading-m">{{ localise("reports:prnSectionHeading") }}</h3>
        {% endif %}

        {% set prnRows = [
          {
            key: { text: localise("reports:pernTotalIssuedTonnage") if isExporter else localise("reports:prnTotalIssuedTonnage") },
            value: { text: prn.issuedTonnage | formatWholeNumberTonnage }
          }
        ] %}

        {% if prn.totalRevenue is defined and prn.totalRevenue !== null %}
          {% set prnRows = prnRows.concat([{
            key: { text: localise("reports:checkPrnRevenueLabel") },
            value: { text: prn.totalRevenue | formatCurrency },
            actions: {
              items: [{
                href: prnRevenueChangeUrl,
                text: changeText,
                visuallyHiddenText: localise("reports:checkPrnRevenueLabel")
              }]
            }
          }]) %}
        {% endif %}

        {% if prn.freeTonnage is defined and prn.freeTonnage !== null %}
          {% set freeTonnageHtml %}
            {{ prn.freeTonnage }}
            <p class="govuk-body-s govuk-!-margin-top-1 govuk-!-margin-bottom-0">{{ localise("reports:checkFreePernNote") }}</p>
          {% endset %}
          {% set prnRows = prnRows.concat([{
            key: { text: localise("reports:checkFreePernLabel") },
            value: { html: freeTonnageHtml },
            actions: {
              items: [{
                href: freePernChangeUrl,
                text: changeText,
                visuallyHiddenText: localise("reports:checkFreePernLabel")
              }]
            }
          }]) %}
        {% endif %}

        {% if prn.averagePricePerTonne is defined and prn.averagePricePerTonne !== null %}
          {% set prnRows = prnRows.concat([{
            key: { text: localise("reports:checkAvgPriceLabel") },
            value: { text: prn.averagePricePerTonne | formatCurrency }
          }]) %}
        {% endif %}

        {{ govukSummaryList({ rows: prnRows }) }}
      {% endif %}

      <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

      <h2 class="govuk-heading-l">{{ localise("reports:checkSupportingInformationHeading") }}</h2>

      {{ govukSummaryList({
        rows: [
          {
            key: { text: supportingInformationLabel },
            value: { text: supportingInformation },
            actions: {
              items: [
                {
                  href: changeUrl,
                  text: changeText,
                  visuallyHiddenText: supportingInformationLabel
                }
              ]
            }
          }
        ]
      }) }}

      <form method="POST" novalidate>
        <input type="hidden" name="crumb" value="{{ crumb }}" />
        <input type="hidden" name="version" value="{{ version }}" />

        {{ govukButton({
          text: createButtonText
        }) }}

        <p class="govuk-body">
          <a href="{{ deleteUrl }}" class="govuk-link">{{ localise("reports:deleteAndStartAgainLink") }}</a>
        </p>
      </form>

    </div>
  </div>
{% endblock %}
