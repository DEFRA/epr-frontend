{% extends 'layouts/page.njk' %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/table/macro.njk" import govukTable %}

{% block beforeContent %}
  {{ govukBackLink({
    text: localise("common:back"),
    href: backUrl
  }) }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <span class="govuk-caption-xl">{{ caption }}</span>
      <h1 class="govuk-heading-xl">{{ heading }}</h1>

      {{ govukSummaryList({
        rows: [
          {
            key: { text: localise("reports:periodColumn") },
            value: { text: cadenceLabel }
          },
          {
            key: { text: localise("reports:accreditationLabel") if isAccredited else localise("reports:registrationLabel") },
            value: { text: accreditationNumber if isAccredited else registrationNumber }
          },
          {
            key: { text: localise("reports:materialLabel") },
            value: { text: material }
          }
        ].concat([{
          key: { text: localise("reports:siteLabel") },
          value: { text: site.address.line1 }
        }] if site else [])
      }) }}

      <h2 class="govuk-heading-l">{{ localise("reports:checkSummaryLogDataHeading") }}</h2>
      {{ govukInsetText({
        text: localise("reports:checkSummaryLogDataGuidance")
      }) }}

      <h3 class="govuk-heading-l">{{ wasteReceivedHeading }}</h3>

      <p class="govuk-caption-l govuk-!-margin-bottom-1">{{ localise("reports:totalTonnageReceived") }}</p>
      <p class="govuk-heading-l">{{ wasteReceived.totalTonnage | formatTonnage }}</p>

      {% if wasteReceived.supplierDetailRows | length > 0 %}
        {{ govukTable({
          head: [
            { text: localise("reports:supplierColumn") },
            { text: localise("reports:activityColumn") },
            { text: localise("reports:addressColumn") },
            { text: localise("reports:phoneColumn") },
            { text: localise("reports:emailColumn") }
          ],
          rows: wasteReceived.supplierDetailRows
        }) }}
      {% endif %}

      {% if isExporter %}
        <h3 class="govuk-heading-l">{{ localise("reports:wasteExportedHeading") }}</h3>

        <p class="govuk-caption-l govuk-!-margin-bottom-1">{{ localise("reports:totalTonnageExported") }}</p>
        <p class="govuk-heading-l">{{ wasteExported.totalTonnage | formatTonnage }}</p>

        {% if wasteExported.overseasSiteRows | length > 0 %}
          {{ govukTable({
            head: [
              { text: localise("reports:siteNameColumn") },
              { text: localise("reports:osrIdColumn") },
              { text: localise("reports:countryColumn") }
            ],
            rows: wasteExported.overseasSiteRows
          }) }}
        {% endif %}

        <h3 class="govuk-heading-l">{{ localise("reports:tonnageReceivedNotExportedHeading") }}</h3>

        <p class="govuk-caption-l govuk-!-margin-bottom-1">{{ localise("reports:tonnageReceivedNotExportedLabel") }}</p>
        <p class="govuk-heading-l">{{ wasteExported.tonnageReceivedNotExported }}</p>

        <h3 class="govuk-heading-l">{{ localise("reports:tonnageRefusedOrStoppedHeading") }}</h3>

        <p class="govuk-caption-l govuk-!-margin-bottom-1">{{ localise("reports:tonnageRefusedOrStoppedLabel") }}</p>
        <p class="govuk-heading-l">{{ wasteExported.tonnageRefusedOrStopped }}</p>

        {{ govukTable({
          rows: [
            [{ html: "<strong>" ~ localise("reports:tonnageRefusedLabel") ~ "</strong>" }, { text: wasteExported.tonnageRefused }],
            [{ html: "<strong>" ~ localise("reports:tonnageStoppedLabel") ~ "</strong>" }, { text: wasteExported.tonnageStopped }],
            [{ html: "<strong>" ~ localise("reports:tonnageRepatriatedLabel") ~ "</strong>" }, { text: wasteExported.tonnageRepatriated }]
          ]
        }) }}
      {% endif %}

      <h3 class="govuk-heading-l">{{ localise("reports:wasteSentOnHeading") }}</h3>

      <p class="govuk-caption-l govuk-!-margin-bottom-1">{{ localise("reports:totalTonnageSentOn") }}</p>
      <p class="govuk-heading-l">{{ wasteSentOn.totalTonnage | formatTonnage }}</p>

      {{ govukTable({
        rows: [
          [{ html: "<strong>" ~ localise("reports:tonnageSentOnToReprocessors") ~ "</strong>" }, { text: wasteSentOn.toReprocessors | formatTonnage }],
          [{ html: "<strong>" ~ localise("reports:tonnageSentOnToExporters") ~ "</strong>" }, { text: wasteSentOn.toExporters | formatTonnage }],
          [{ html: "<strong>" ~ localise("reports:tonnageSentOnToOtherSites") ~ "</strong>" }, { text: wasteSentOn.toOtherSites | formatTonnage }]
        ]
      }) }}

      {% if wasteSentOn.destinationDetailRows | length > 0 %}
          {{ govukTable({
            head: [
              { text: localise("reports:recipientColumn") },
              { text: localise("reports:activityColumn") },
              { text: localise("reports:addressColumn") },
              { text: localise("reports:tonnageSentOnColumn") }
            ],
            rows: wasteSentOn.destinationDetailRows
          }) }}
      {% endif %}

      {% if isReprocessor %}

        <h2 class="govuk-heading-l">{{ localise("reports:checkRecyclingActivityHeading") }}</h2>

        {{ govukSummaryList({
          rows: [
            {
              key: { text: localise("reports:checkTonnageRecycledLabel") },
              value: { text: recyclingActivity.tonnageRecycled if recyclingActivity.tonnageRecycled !== null else "—" },
              actions: {
                items: [{
                  href: tonnageRecycledChangeUrl,
                  text: changeText,
                  visuallyHiddenText: localise("reports:checkTonnageRecycledLabel")
                }]
              }
            },
            {
              key: { text: localise("reports:checkTonnageNotRecycledLabel") },
              value: { text: recyclingActivity.tonnageNotRecycled if recyclingActivity.tonnageNotRecycled !== null else "—" },
              actions: {
                items: [{
                  href: tonnageNotRecycledChangeUrl,
                  text: changeText,
                  visuallyHiddenText: localise("reports:checkTonnageNotRecycledLabel")
                }]
              }
            }
          ]
        }) }}
      {% endif %}

      {% if prn and (isExporter or (isReprocessor and isAccredited)) %}

        <h3 class="govuk-heading-m">{{ noteTypeSectionHeading }}</h3>

        {% set prnRows = [
          {
            key: { text: totalIssuedTonnageLabel },
            value: { text: prn.issuedTonnage | formatWholeNumberTonnage }
          }
        ] %}

        {% if prn.totalRevenue is defined and prn.totalRevenue !== null %}
          {% set prnRows = prnRows.concat([{
            key: { text: revenueLabel },
            value: { text: prn.totalRevenue | formatCurrency },
            actions: {
              items: [{
                href: prnRevenueChangeUrl,
                text: changeText,
                visuallyHiddenText: revenueLabel
              }]
            }
          }]) %}
        {% endif %}

        {% if prn.freeTonnage is defined and prn.freeTonnage !== null %}
          {% set freeTonnageHtml %}
            {{ prn.freeTonnage }}
            <p class="govuk-body-s govuk-!-margin-top-1 govuk-!-margin-bottom-0">{{ freeNote }}</p>
          {% endset %}
          {% set freeTonnageChangeUrl = freePrnsChangeUrl if isReprocessor else freePernChangeUrl %}
          {% set prnRows = prnRows.concat([{
            key: { text: freeLabel },
            value: { html: freeTonnageHtml },
            actions: {
              items: [{
                href: freeTonnageChangeUrl,
                text: changeText,
                visuallyHiddenText: freeLabel
              }]
            }
          }]) %}
        {% endif %}

        {% if prn.averagePricePerTonne is defined and prn.averagePricePerTonne !== null %}
          {% set prnRows = prnRows.concat([{
            key: { text: localise("reports:checkAvgPriceLabel") },
            value: { text: prn.averagePricePerTonne | formatCurrency }
          }]) %}
        {% endif %}

        {{ govukSummaryList({ rows: prnRows }) }}
      {% endif %}

      <h2 class="govuk-heading-l">{{ localise("reports:checkSupportingInformationHeading") }}</h2>

      {{ govukSummaryList({
        rows: [
          {
            key: { text: supportingInformationLabel },
            value: { text: supportingInformation },
            actions: {
              items: [
                {
                  href: changeUrl,
                  text: changeText,
                  visuallyHiddenText: supportingInformationLabel
                }
              ]
            }
          }
        ]
      }) }}

      <form method="POST" novalidate>
        <input type="hidden" name="crumb" value="{{ crumb }}" />
        <input type="hidden" name="version" value="{{ version }}" />

        {{ govukButton({
          text: createButtonText
        }) }}

        <p class="govuk-body">
          <a href="{{ deleteUrl }}" class="govuk-link">{{ localise("reports:deleteAndStartAgainLink") }}</a>
        </p>
      </form>

    </div>
  </div>
{% endblock %}
