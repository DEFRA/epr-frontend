{% extends 'layouts/page.njk' %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-xl">{{ heading }}</h1>

      <p class="govuk-body">{{ bodyLine1 }}</p>
      <p class="govuk-body">{{ bodyLine2 }}</p>

      <div class="govuk-button-group">
        {{ govukButton({
          text: localise('reports:reportStaleDeleteAndStartAgain'),
          classes: "govuk-button--warning",
          preventDoubleClick: true,
          attributes: { form: "delete-report-form" }
        }) }}

        {{ govukButton({
          text: localise('reports:reportStaleReturnToReports'),
          href: returnToReportsUrl,
          classes: "govuk-button--secondary"
        }) }}
      </div>

      <form id="delete-report-form" method="POST" novalidate>
        <input type="hidden" name="crumb" value="{{ crumb }}" />
      </form>

    </div>
  </div>
{% endblock %}
