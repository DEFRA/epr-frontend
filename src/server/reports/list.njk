{% extends 'layouts/page.njk' %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/table/macro.njk" import govukTable %}

{% block beforeContent %}
  {{ govukBackLink({
    text: localise("common:back"),
    href: backUrl
  }) }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">

      <h1 class="govuk-heading-l">
        <span class="govuk-caption-l">{{ material }}</span>
        {{ heading }}
      </h1>

      {% if approvedPersonBanner %}
        <div class="govuk-warning-text">
          <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
          <strong class="govuk-warning-text__text">
            <span class="govuk-visually-hidden">{{ localise("common:warning") }}</span>
            {{ approvedPersonBanner }}
          </strong>
        </div>
      {% endif %}

      <h3 class="govuk-heading-m">{{ localise("reports:actionRequiredHeading") }}</h3>
      {% if active.rows.length %}
        {{ govukTable({
          head: active.head,
          rows: active.rows
        }) }}
      {% else %}
        <p class="govuk-body app-colour-secondary">{{ active.emptyMessage }}</p>
      {% endif %}

      <h3 class="govuk-heading-m">{{ localise("reports:submittedSectionHeading") }}</h3>
      {% if submitted.rows.length %}
        {{ govukTable({
          head: submitted.head,
          rows: submitted.rows
        }) }}
      {% else %}
        <p class="govuk-body app-colour-secondary">{{ submitted.emptyMessage }}</p>
      {% endif %}

    </div>
  </div>
{% endblock %}
