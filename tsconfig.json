{
  "compilerOptions": {
    "target": "es2024",
    "lib": ["ES2024"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "paths": {
      "#vite/*": ["./.vite/*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strictFunctionTypes": true,
    "strictNullChecks": true
  },
  "exclude": [".cache", ".public", ".server", "coverage", "node_modules"],
  "include": [
    "**/*.cjs",
    "**/*.d.ts",
    "**/*.js",
    ".eslintrc.*",
    ".prettierrc.*",
    ".vite/**/*.js"
  ]
}
