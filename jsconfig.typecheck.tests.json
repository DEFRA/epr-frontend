{
  "extends": "./jsconfig.typecheck.json",
  "compilerOptions": {
    "types": ["vitest/globals", "@testing-library/jest-dom"]
  },
  "include": [
    "**/*.test.js",
    "**/*.contract.js",
    "**/*-test-helpers.js",
    "**/test-helpers/**/*.js",
    "**/test-fixtures.js",
    "**/*.d.ts"
  ],
  "exclude": ["node_modules", ".vite"]
}
